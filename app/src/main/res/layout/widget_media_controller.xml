<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="12dp"
    android:background="@drawable/widget_background">

    <LinearLayout
        android:id="@+id/widget_logo_container"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:clickable="true"
        android:focusable="true"
        android:gravity="center_vertical"
        android:layout_alignParentTop="true"
        android:layout_alignParentStart="true">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="✦ "
            android:textColor="#00FFCC"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Hexaro Cinema"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:textStyle="bold" />
    </LinearLayout>

    <TextView
        android:id="@+id/widget_subtitle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Discover live streams &amp; playlists"
        android:textColor="#9CA3AF"
        android:textSize="10sp"
        android:layout_below="@id/widget_logo_container"
        android:layout_alignParentStart="true"
        android:layout_marginTop="2dp" />

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:layout_below="@id/widget_subtitle"
        android:layout_marginTop="12dp"
        android:weightSum="2">

        <Button
            android:id="@+id/widget_search_btn"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="Search"
            android:textColor="#FFFFFF"
            android:textSize="11sp"
            style="?android:attr/buttonStyleSmall"
            android:background="#2E1B4E"
            android:layout_marginEnd="4dp" />

        <Button
            android:id="@+id/widget_open_app_btn"
            android:layout_width="0dp"
            android:layout_height="32dp"
            android:layout_weight="1"
            android:text="Open Player"
            android:textColor="#111827"
            android:textSize="11sp"
            style="?android:attr/buttonStyleSmall"
            android:background="#00FFCC"
            android:layout_marginStart="4dp" />
    </LinearLayout>

</RelativeLayout>
